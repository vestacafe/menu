<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vesta Cafe — Menü</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --ink: #1a1208;
  --ink2: #2f2010;
  --sand: #f5ede0;
  --sand2: #ede0cc;
  --sand3: #d4c4aa;
  --amber: #c97b2a;
  --amber-light: #e8a84e;
  --amber-pale: #faf0dc;
  --rust: #b34a1e;
  --green: #3a5c3a;
  --green-light: #5a8c5a;
  --cream: #fdf9f2;
  --white: #fffef9;
  --muted: #8a6e54;
}

body {
  background: var(--sand);
  font-family: 'DM Sans', sans-serif;
  color: var(--ink);
  min-height: 100vh;
}

/* ───────── HEADER ───────── */
.header {
  background: var(--ink);
  padding: 0;
  position: relative;
  overflow: hidden;
}
.header-inner {
  display: flex;
  align-items: stretch;
  min-height: 220px;
}
.header-left {
  flex: 1;
  padding: 48px 56px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 2;
}
.header-right {
  width: 280px;
  background: var(--amber);
  clip-path: polygon(40px 0, 100% 0, 100% 100%, 0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 40px 40px 60px;
}
.logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 88px;
  color: var(--white);
  letter-spacing: 8px;
  line-height: 0.9;
  margin-bottom: 12px;
}
.tagline {
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--sand3);
}
.header-info {
  font-size: 13px;
  color: var(--ink);
  font-weight: 500;
  text-align: center;
  line-height: 2;
}
.header-info strong {
  display: block;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 2px;
  color: var(--ink);
  margin-bottom: 4px;
}

/* Decorative grid lines */
.header-grid {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image: 
    repeating-linear-gradient(0deg, #fff 0, #fff 1px, transparent 1px, transparent 40px),
    repeating-linear-gradient(90deg, #fff 0, #fff 1px, transparent 1px, transparent 40px);
}

/* ───────── NAV ───────── */
.nav {
  background: var(--ink2);
  display: flex;
  overflow-x: auto;
  scrollbar-width: none;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav::-webkit-scrollbar { display: none; }
.nav-tab {
  flex-shrink: 0;
  padding: 15px 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--sand3);
  cursor: pointer;
  border: none;
  background: transparent;
  transition: all 0.2s;
  border-bottom: 3px solid transparent;
  white-space: nowrap;
}
.nav-tab:hover { color: var(--white); background: rgba(255,255,255,0.05); }
.nav-tab.active { color: var(--amber-light); border-bottom-color: var(--amber); }

/* ───────── LAYOUT ───────── */
.page { max-width: 1040px; margin: 0 auto; padding: 50px 32px 80px; }
.section { display: none; }
.section.active { display: block; }

.section-head {
  display: flex;
  align-items: flex-end;
  gap: 24px;
  margin-bottom: 36px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--sand3);
}
.section-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 80px;
  color: var(--sand2);
  line-height: 1;
}
.section-title-group { flex: 1; }
.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 42px;
  color: var(--ink);
  letter-spacing: 3px;
  line-height: 1;
  margin-bottom: 4px;
}
.section-desc {
  font-size: 13px;
  color: var(--muted);
  font-style: italic;
}

/* ───────── SANDVIÇ CARDS ───────── */
.sandvic-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
  margin-bottom: 10px;
}
.sandvic-card {
  background: var(--white);
  border: 1px solid var(--sand2);
  border-top: 4px solid var(--amber);
  padding: 24px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.sandvic-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(26,18,8,0.1);
}
.sandvic-card.tatlı { border-top-color: var(--rust); }
.sandvic-card.sosisli { border-top-color: var(--green); }

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10px;
}
.card-name {
  font-weight: 500;
  font-size: 17px;
  color: var(--ink);
  flex: 1;
  padding-right: 12px;
}
.card-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  color: var(--amber);
  line-height: 1;
  white-space: nowrap;
}
.card-price span { font-size: 14px; }
.card-desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.65;
}
.card-tag {
  display: inline-block;
  margin-top: 12px;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 2px;
}
.card-tag.özel { background: var(--amber-pale); color: var(--amber); }
.card-tag.tatlı { background: #fdf0ec; color: var(--rust); }
.card-tag.et { background: #f0f4f0; color: var(--green); }

/* ───────── TOST LIST ───────── */
.tost-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@media (max-width: 600px) { .tost-grid { grid-template-columns: 1fr; } }

.tost-item {
  background: var(--white);
  border: 1px solid var(--sand2);
  padding: 16px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.15s;
}
.tost-item:hover { background: var(--amber-pale); }
.tost-item-left { flex: 1; padding-right: 16px; }
.tost-name { font-weight: 500; font-size: 15px; color: var(--ink); margin-bottom: 3px; }
.tost-desc { font-size: 12px; color: var(--muted); }
.tost-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px;
  color: var(--amber);
  white-space: nowrap;
}

/* ───────── KAHVE ───────── */
.kahve-section { margin-bottom: 44px; }
.kahve-section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 3px;
  color: var(--ink);
  margin-bottom: 14px;
  padding: 8px 14px;
  background: var(--ink);
  color: var(--amber-light);
  display: inline-block;
}
.kahve-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 10px;
}
.kahve-item {
  background: var(--white);
  border: 1px solid var(--sand2);
  padding: 14px 18px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.kahve-name { font-weight: 500; font-size: 14px; color: var(--ink); }
.kahve-prices {
  display: flex;
  gap: 12px;
}
.kahve-price-set {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.kahve-size { font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); }
.kahve-price-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  color: var(--amber);
  line-height: 1.1;
}
.kahve-divider { width: 1px; background: var(--sand2); }

/* ───────── İÇECEK ───────── */
.icecek-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 12px;
}
.icecek-item {
  background: var(--white);
  border: 1px solid var(--sand2);
  padding: 18px 16px;
  text-align: center;
  transition: transform 0.2s;
}
.icecek-item:hover { transform: translateY(-2px); }
.icecek-emoji { font-size: 28px; margin-bottom: 8px; }
.icecek-name { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 6px; }
.icecek-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  color: var(--amber);
}

/* ───────── TATLILER ───────── */
.tatli-group { margin-bottom: 36px; }
.tatli-group-title {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 14px;
  padding-bottom: 8px;
  border-bottom: 1px dashed var(--sand3);
}
.tatli-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}
.tatli-item {
  background: var(--white);
  border: 1px solid var(--sand2);
  padding: 18px 20px;
  border-left: 4px solid var(--rust);
  transition: box-shadow 0.2s;
}
.tatli-item.muffin { border-left-color: var(--green-light); }
.tatli-item.pasta-item { border-left-color: var(--amber); }
.tatli-item:hover { box-shadow: 4px 0 0 var(--rust), 0 4px 16px rgba(0,0,0,0.07); }
.tatli-item.muffin:hover { box-shadow: 4px 0 0 var(--green-light), 0 4px 16px rgba(0,0,0,0.07); }
.tatli-item.pasta-item:hover { box-shadow: 4px 0 0 var(--amber), 0 4px 16px rgba(0,0,0,0.07); }
.tatli-name { font-weight: 500; font-size: 15px; color: var(--ink); margin-bottom: 8px; }
.tatli-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px;
  color: var(--rust);
}
.tatli-item.muffin .tatli-price { color: var(--green-light); }
.tatli-item.pasta-item .tatli-price { color: var(--amber); }

/* ───────── FOOTER ───────── */
.footer {
  background: var(--ink);
  padding: 36px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.footer-brand {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px;
  color: var(--white);
  letter-spacing: 4px;
}
.footer-brand span { color: var(--amber); }
.footer-note { font-size: 13px; color: var(--sand3); font-style: italic; }

/* ───────── ANIMATIONS ───────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
.section.active .sandvic-card,
.section.active .tost-item,
.section.active .kahve-item,
.section.active .icecek-item,
.section.active .tatli-item {
  animation: fadeUp 0.3s ease both;
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="header-grid"></div>
  <div class="header-inner">
    <div class="header-left">
      <div class="logo">VESTA</div>
      <div class="tagline">Cafe &amp; Sandviç</div>
    </div>
    <div class="header-right">
      <div class="header-info">
        <strong>Menü</strong>
        Taze &amp; Lezzetli<br>
        Her gün açık
      </div>
    </div>
  </div>
</header>

<!-- NAV -->
<nav class="nav">
  <button class="nav-tab active" onclick="showTab('sandvic',this)">Sandviçler</button>
  <button class="nav-tab" onclick="showTab('tost',this)">Tostlar</button>
  <button class="nav-tab" onclick="showTab('kahve',this)">Kahveler</button>
  <button class="nav-tab" onclick="showTab('icecek',this)">İçecekler</button>
  <button class="nav-tab" onclick="showTab('tatli',this)">Tatlılar</button>
</nav>

<div class="page">

  <!-- ─── SANDVİÇLER ─── -->
  <section class="section active" id="sandvic">
    <div class="section-head">
      <div class="section-num">01</div>
      <div class="section-title-group">
        <div class="section-title">Sandviçler</div>
        <div class="section-desc">İstediğiniz malzemelerle kişiye özel hazırlanır</div>
      </div>
    </div>
    <div class="sandvic-grid">
      <div class="sandvic-card">
        <div class="card-top">
          <div class="card-name">Tuzlu Sandviç</div>
          <div class="card-price">300 <span>₺</span></div>
        </div>
        <div class="card-desc">Labne, zeytin ezmesi, acuka, pesto sos, zeytin salatası, rus salatası, kaşar, cheddar, çeçil, ezine &amp; beyaz peynir, hindi füme/salam/jambon, piliç jambon, dana füme/salam/jambon, italyan salam, kıvırcık, domates, avokado, salatalık, biber, maydanoz, roka, ketçap, mayonez, sriracha &amp; baharatlar</div>
        <span class="card-tag özel">Kişiye Özel</span>
      </div>
      <div class="sandvic-card">
        <div class="card-top">
          <div class="card-name">Yumurtalı Sandviç</div>
          <div class="card-price">350 <span>₺</span></div>
        </div>
        <div class="card-desc">Tosta kırılmış yumurta + tuzlu sandviç malzemelerin tümü — labne, zeytin ezmesi, acuka, pesto sos, çeşit peynirler, şarküteri seçenekleri, taze sebzeler ve soslar</div>
        <span class="card-tag özel">Kişiye Özel</span>
      </div>
      <div class="sandvic-card tatlı">
        <div class="card-top">
          <div class="card-name">Tatlı Sandviç</div>
          <div class="card-price">250 <span>₺</span></div>
        </div>
        <div class="card-desc">Kaymak, bal, fıstık kreması, nutella, crunch, fındık ezmesi, çilek, muz, fındık kırığı, hindistan cevizi tozu — isteğe göre vişne/çilek reçeli veya tahin pekmez de eklenir</div>
        <span class="card-tag tatlı">Tatlı</span>
      </div>
      <div class="sandvic-card sosisli">
        <div class="card-top">
          <div class="card-name">Sosisli Sandviç</div>
          <div class="card-price">200 <span>₺</span></div>
        </div>
        <div class="card-desc">2 adet uzun piliç sosis, bol rus salatası, salatalık turşusu, ketçap, mayonez ile isteğinize göre hazırlanır</div>
        <span class="card-tag et">Piliç Sosis</span>
      </div>
      <div class="sandvic-card sosisli">
        <div class="card-top">
          <div class="card-name">Kaşarlı Sosisli Sandviç</div>
          <div class="card-price">250 <span>₺</span></div>
        </div>
        <div class="card-desc">2 uzun piliç sosis, bol rus salatası, salatalık turşusu, ketçap, mayonez ve üzerinde eritilmiş kaşar peyniri</div>
        <span class="card-tag et">Piliç Sosis</span>
      </div>
      <div class="sandvic-card sosisli">
        <div class="card-top">
          <div class="card-name">Hotdog</div>
          <div class="card-price">150 <span>₺</span></div>
        </div>
        <div class="card-desc">Küçük sandviç ekmeğine uzun piliç sosis, rus salatası, salatalık turşusu, ketçap, mayonez, hardal ile hazırlanır</div>
        <span class="card-tag et">Piliç Sosis</span>
      </div>
    </div>
  </section>

  <!-- ─── TOSTLAR ─── -->
  <section class="section" id="tost">
    <div class="section-head">
      <div class="section-num">02</div>
      <div class="section-title-group">
        <div class="section-title">Tostlar</div>
        <div class="section-desc">Normal ekmek ve bazlama seçeneğiyle</div>
      </div>
    </div>
    <div class="tost-grid">
      <div class="tost-item">
        <div class="tost-item-left">
