      </div>
    </div>
  </section>

  <!-- ─── KAHVELER ─── -->
  <section class="section" id="kahve">
    <div class="section-head">
      <div class="section-num">03</div>
      <div class="section-title-group">
        <div class="section-title">Kahveler</div>
        <div class="section-desc">Sıcak ve soğuk seçeneklerle, küçük / büyük boy</div>
      </div>
    </div>

    <div class="kahve-section">
      <div class="kahve-section-title">☕ Sıcak Kahveler</div>
      <div class="kahve-grid">
        <div class="kahve-item">
          <div class="kahve-name">Espresso</div>
          <div class="kahve-prices">
            <div class="kahve-price-set"><span class="kahve-size">Tek</span><span class="kahve-price-val">80₺</span></div>
            <div class="kahve-divider"></div>
            <div class="kahve-price-set"><span class="kahve-size">Duble</span><span class="kahve-price-val">120₺</span></div>
          </div>
        </div>
        <div class="kahve-item">
          <div class="kahve-name">Americano</div>
