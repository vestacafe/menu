        </div>
        <div class="tost-price">200 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Yumurtalı Otlu Karışık Tost</div>
          <div class="tost-desc">Kırık yumurta, salça, pesto, sucuk, kaşar, kıvırcık, roka, maydanoz, nane</div>
        </div>
        <div class="tost-price">300 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Yumurtalı Otlu Kaşarlı Tost</div>
          <div class="tost-desc">Kırık yumurta, salça, pesto, kaşar, kıvırcık, roka, maydanoz, nane</div>
        </div>
        <div class="tost-price">250 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Karışık Tost</div>
          <div class="tost-desc">Salça, sucuk, kaşar peyniri, kekik, pul biber</div>
        </div>
        <div class="tost-price">200 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Sucuklu Tost</div>
          <div class="tost-desc">Salça, sucuk, kekik, pul biber</div>
        </div>
        <div class="tost-price">180 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Kaşarlı Tost</div>
          <div class="tost-desc">Salça, kaşar peyniri, kekik, pul biber</div>
        </div>
        <div class="tost-price">180 ₺</div>
      </div>
