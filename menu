        </div>
        <div class="tost-price">250 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Bazlama Kaşarlı Tost</div>
          <div class="tost-desc">Bazlama ekmeğinde salça, kaşar, kekik, pul biber</div>
        </div>
        <div class="tost-price">200 ₺</div>
      </div>
      <div class="tost-item">
        <div class="tost-item-left">
          <div class="tost-name">Bazlama Sucuklu Tost</div>
          <div class="tost-desc">Bazlama ekmeğinde salça, sucuk, kekik, pul biber</div>
        </div>
        <div class="tost-price">200 ₺</div>
      </div>
      <div class="tost-item" style="border-top: 3px solid var(--amber); grid-column: 1 / -1;">
